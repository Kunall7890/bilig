{
  "name": "@bilig/workbook",
  "version": "0.96.0",
  "description": "Agent-first workbook model API and transport-neutral workbook operation language for bilig.",
  "keywords": [
    "agent-first",
    "bilig",
    "models",
    "spreadsheet",
    "workbook"
  ],
  "homepage": "https://github.com/proompteng/bilig/tree/main/packages/workbook#readme",
  "bugs": {
    "url": "https://github.com/proompteng/bilig/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/proompteng/bilig.git",
    "directory": "packages/workbook"
  },
  "files": [
    "dist",
    "fixtures",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./model": {
      "types": "./dist/model.d.ts",
      "import": "./dist/model.js",
      "default": "./dist/model.js"
    },
    "./find": {
      "types": "./dist/find.d.ts",
      "import": "./dist/find.js",
      "default": "./dist/find.js"
    },
    "./check": {
      "types": "./dist/check.d.ts",
      "import": "./dist/check.js",
      "default": "./dist/check.js"
    },
    "./formula": {
      "types": "./dist/formula.d.ts",
      "import": "./dist/formula.js",
      "default": "./dist/formula.js"
    },
    "./verify": {
      "types": "./dist/verify.d.ts",
      "import": "./dist/verify.js",
      "default": "./dist/verify.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js",
      "default": "./dist/runtime.js"
    },
    "./command": {
      "types": "./dist/command.d.ts",
      "import": "./dist/command.js",
      "default": "./dist/command.js"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "import": "./dist/schema.js",
      "default": "./dist/schema.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "test": "cd ../.. && tsx scripts/run-vitest.ts --run packages/workbook/src/__tests__/guards.test.ts packages/workbook/src/__tests__/model-api.test.ts packages/workbook/src/__tests__/model-verification-api.test.ts packages/workbook/src/__tests__/transport-api.test.ts packages/workbook/src/__tests__/ref-data-boundary.test.ts packages/workbook/src/__tests__/low-level-op-api.test.ts packages/workbook/src/__tests__/check-api.test.ts packages/workbook/src/__tests__/format-api.test.ts packages/workbook/src/__tests__/formula-api.test.ts packages/workbook/src/__tests__/action-input-api.test.ts packages/workbook/src/__tests__/action-metadata-api.test.ts packages/workbook/src/__tests__/features-api.test.ts packages/workbook/src/__tests__/feature-plugin-boundary.test.ts packages/workbook/src/__tests__/command-bundle-api.test.ts packages/workbook/src/__tests__/run-api.test.ts packages/workbook/src/__tests__/run-proof-boundary.test.ts packages/workbook/src/__tests__/readback-proof-api.test.ts packages/workbook/src/__tests__/run-strict-proof-api.test.ts packages/workbook/src/__tests__/requirements-api.test.ts packages/workbook/src/__tests__/plan-refs-api.test.ts packages/workbook/src/__tests__/prepare-api.test.ts packages/workbook/src/__tests__/schema-api.test.ts packages/workbook/src/__tests__/package-boundary.test.ts"
  },
  "dependencies": {
    "@bilig/formula": "workspace:*",
    "@bilig/protocol": "workspace:*"
  },
  "engines": {
