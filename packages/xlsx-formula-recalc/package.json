{
  "name": "xlsx-formula-recalc",
  "version": "0.163.0",
  "description": "Diagnose stale cached XLSX formula values and recalculate XLSX formulas in Node.js without Excel, LibreOffice, or browser automation.",
  "keywords": [
    "excel",
    "excel-formulas",
    "exceljs",
    "formula-engine",
    "formula-recalculation",
    "formula-result-not-updating",
    "libreoffice-alternative",
    "node",
    "recalculate-xlsx",
    "sheetjs",
    "sheetjs-recalc",
    "spreadsheet",
    "spreadsheet-formulas",
    "stale-xlsx-cache",
    "workbook",
    "workbook-compatibility-report",
    "workbook-risk-report",
    "workpaper",
    "xlsx",
    "xlsx-cache-doctor",
    "xlsx-calc",
    "xlsx-formula",
    "xlsx-formula-recalculation",
    "xlsx-populate",
    "xlsx-recalc",
    "xlsx-recalculation"
  ],
  "homepage": "https://proompteng.github.io/bilig/eval-xlsx-cache-doctor.html",
  "bugs": {
    "url": "https://github.com/proompteng/bilig/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/proompteng/bilig.git",
    "directory": "packages/xlsx-formula-recalc"
  },
  "bin": {
    "bilig-evaluate": "./bin/bilig-evaluate.js",
    "sheetjs-recalc": "./bin/sheetjs-recalc.js",
    "workbook-compatibility-report": "./bin/workbook-compatibility-report.js",
    "xlsx-cache-doctor": "./bin/xlsx-cache-doctor.js",
    "xlsx-recalc": "./bin/xlsx-recalc.js"
  },
  "files": [
    "bin",
    "dist",
    "AGENTS.md",
    "SKILL.md",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./cli-api": {
      "types": "./dist/cli-api.d.ts",
      "import": "./dist/cli-api.js",
      "default": "./dist/cli-api.js"
    },
    "./evaluator": {
      "types": "./dist/evaluator-cli.d.ts",
      "import": "./dist/evaluator-cli.js",
      "default": "./dist/evaluator-cli.js"
    },
    "./legacy-workpaper": {
      "types": "./dist/legacy-workpaper.d.ts",
      "import": "./dist/legacy-workpaper.js",
      "default": "./dist/legacy-workpaper.js"
    },
    "./workbook-compatibility-report": {
      "types": "./dist/workbook-compatibility-report.d.ts",
      "import": "./dist/workbook-compatibility-report.js",
      "default": "./dist/workbook-compatibility-report.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "pnpm --dir ../.. --filter @bilig/wasm-kernel build && pnpm --dir ../.. --filter @bilig/xlsx build && pnpm --dir ../.. --filter @bilig/headless build && rm -rf dist tsconfig.tsbuildinfo && tsc -p tsconfig.json",
    "test:excel-oracle": "tsx ../../scripts/run-vitest.ts --root ../.. --run src/__tests__/macos-desktop-excel-*.test.ts --maxWorkers=1 --pool forks --configLoader runner --reporter=verbose",
    "test:excel-oracle:live": "BILIG_EXCEL_ORACLE_RUN=1 tsx ../../scripts/run-vitest.ts --root ../.. --run src/__tests__/macos-desktop-excel-*.test.ts --maxWorkers=1 --pool forks --configLoader runner --reporter=verbose",
    "smoke": "node ./dist/cli.js --help"
  },
  "dependencies": {
    "@bilig/headless": "workspace:*",
    "@bilig/protocol": "workspace:*",
    "@bilig/xlsx": "workspace:*"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
