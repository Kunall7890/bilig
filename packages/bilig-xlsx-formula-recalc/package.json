{
  "name": "@bilig/xlsx-formula-recalc",
  "version": "0.141.0",
  "description": "Diagnose stale cached XLSX formula values and recalculate XLSX formulas in Node.js without Excel, LibreOffice, or browser automation.",
  "keywords": [
    "bilig",
    "excel",
    "excel-formulas",
    "formula-engine",
    "formula-recalculation",
    "formula-result-not-updating",
    "libreoffice-alternative",
    "node",
    "recalculate-xlsx",
    "sheetjs",
    "sheetjs-recalc",
    "spreadsheet",
    "spreadsheet-formulas",
    "stale-xlsx-cache",
    "workbook",
    "xlsx",
    "xlsx-cache-doctor",
    "xlsx-calc",
    "xlsx-formula",
    "xlsx-formula-recalculation",
    "xlsx-populate",
    "xlsx-recalc",
    "xlsx-recalculation"
  ],
  "homepage": "https://proompteng.github.io/bilig/eval-xlsx-cache-doctor.html",
  "bugs": {
    "url": "https://github.com/proompteng/bilig/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/proompteng/bilig.git",
    "directory": "packages/bilig-xlsx-formula-recalc"
  },
  "bin": {
    "bilig-evaluate": "./bin/bilig-evaluate.js",
    "sheetjs-recalc": "./bin/sheetjs-recalc.js",
    "xlsx-cache-doctor": "./bin/xlsx-cache-doctor.js",
    "xlsx-recalc": "./bin/xlsx-recalc.js"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./cli-api": {
      "types": "./dist/cli-api.d.ts",
      "import": "./dist/cli-api.js",
      "default": "./dist/cli-api.js"
    },
    "./evaluator": {
      "types": "./dist/evaluator.d.ts",
      "import": "./dist/evaluator.js",
      "default": "./dist/evaluator.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "pnpm --dir ../.. --filter xlsx-formula-recalc build && rm -rf dist tsconfig.tsbuildinfo && tsc -p tsconfig.json",
    "smoke": "node ./dist/cli.js --help"
  },
  "dependencies": {
    "xlsx-formula-recalc": "workspace:*"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
