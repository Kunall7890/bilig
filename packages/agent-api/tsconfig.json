{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "paths": {
      "@bilig/binary-protocol": ["../binary-protocol/src/index.ts"],
      "@bilig/contracts": ["../contracts/src/index.ts"],
      "@bilig/core": ["../core/src/index.ts"],
      "@bilig/formula": ["../formula/src/index.ts"],
      "@bilig/protocol": ["../protocol/src/index.ts"],
      "@bilig/workbook": ["../workbook/src/index.ts"]
    }
  },
  "references": [
    {
      "path": "../binary-protocol"
    },
    {
      "path": "../contracts"
    },
    {
      "path": "../core"
    },
    {
      "path": "../formula"
    },
    {
      "path": "../protocol"
    },
    {
      "path": "../workbook"
    }
  ],
  "include": ["src/**/*"],
  "exclude": ["src/**/__tests__/**"]
}
