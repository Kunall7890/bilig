{
  "mcpServers": {
    "bilig-workpaper": {
      "command": "npm",
      "args": [
        "exec",
        "--yes",
        "--package",
        "@bilig/workpaper@latest",
        "--",
        "bilig-workpaper-mcp",
        "--workpaper",
        "__WORKPAPER_PATH__",
        "--init-demo-workpaper",
        "--writable"
      ],
      "env": {}
    }
  }
}
