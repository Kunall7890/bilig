{
  "name": "@bilig/xlsx",
  "version": "0.163.0",
  "description": "@bilig/xlsx ZIP, address, and source-preserving patch primitives for Bilig.",
  "keywords": [
    "bilig",
    "source-preserving",
    "spreadsheet",
    "xlsx",
    "zip"
  ],
  "homepage": "https://github.com/proompteng/bilig/tree/main/packages/xlsx#readme",
  "bugs": {
    "url": "https://github.com/proompteng/bilig/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/proompteng/bilig.git",
    "directory": "packages/xlsx"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./address": {
      "types": "./dist/address.d.ts",
      "import": "./dist/address.js",
      "default": "./dist/address.js"
    },
    "./source-preserving-zip": {
      "types": "./dist/source-preserving-zip.d.ts",
      "import": "./dist/source-preserving-zip.js",
      "default": "./dist/source-preserving-zip.js"
    },
    "./source-preserving-literal-patches": {
      "types": "./dist/source-preserving-literal-patches.d.ts",
      "import": "./dist/source-preserving-literal-patches.js",
      "default": "./dist/source-preserving-literal-patches.js"
    },
    "./simple-workbook-writer": {
      "types": "./dist/simple-workbook-writer.d.ts",
      "import": "./dist/simple-workbook-writer.js",
      "default": "./dist/simple-workbook-writer.js"
    },
    "./zip-reader": {
      "types": "./dist/zip-reader.d.ts",
      "import": "./dist/zip-reader.js",
      "default": "./dist/zip-reader.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
