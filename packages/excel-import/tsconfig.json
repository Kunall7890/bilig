{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "paths": {
      "@bilig/core": ["../core/src/index.ts"],
      "@bilig/protocol": ["../protocol/src/index.ts"]
    }
  },
  "references": [
    {
      "path": "../core"
    },
    {
      "path": "../protocol"
    }
  ],
  "include": ["src/**/*"],
  "exclude": ["src/**/__tests__/**"]
}
