{
  "name": "bilig-temporal-workpaper-activity",
  "private": true,
  "description": "Temporal TypeScript Activity example that calculates Bilig WorkPaper formula output outside Workflow replay code.",
  "type": "module",
  "scripts": {
    "check": "tsc -p tsconfig.json --noEmit && tsx scripts/check-temporal-boundary.ts",
    "smoke": "tsx src/smoke.ts --output .tmp/workpaper-proof.json"
  },
  "dependencies": {
    "@bilig/workpaper": "latest",
    "@temporalio/workflow": "1.17.2"
  },
  "devDependencies": {
    "@temporalio/testing": "1.17.2",
    "@types/node": "25.5.0",
    "tsx": "4.21.0",
    "typescript": "6.0.2"
  }
}
